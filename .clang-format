UseCRLF: false            # 是否使用 Windows 风格换行

AccessModifierOffset: -4              # 访问修饰符相对 class 的缩进偏移量
IndentWidth: 4                        # 一个缩进级别占用的列数
TabWidth: 4                           # 一个 Tab 占用的列数（当使用 Tab 缩进时）
UseTab: ForContinuationAndIndentation # 缩进方式
IndentAccessModifiers: false          # 是否缩进访问修饰符
IndentCaseBlocks: false               # 是否缩进 case 块内的语句（不包含 case 标签本身）
IndentCaseLabels: false               # 是否将 case 标签缩进一级（相对 switch）
IndentExternBlock: AfterExternBlock   # extern "C" / extern "C++" 块的缩进风格：AfterExternBlock, Indent, NoIndent
IndentGotoLabels: false               # 是否将 goto 标签缩进一级
IndentPPDirectives: None              # 预处理指令缩进风格：None(不缩进), AfterHash(在 # 后缩进), BeforeHash(在 # 前缩进)
IndentRequiresClause: true            # 是否缩进 requires 子句
IndentWrappedFunctionNames: false     # 函数名过长换行后是否缩进函数名
LambdaBodyIndentation: Signature      # Lambda 体的缩进风格：Signature(对齐参数), OuterScope(外层作用域缩进)
NamespaceIndentation: All             # 命名空间缩进
PPIndentWidth: -1                     # 预处理指令缩进的宽度，-1 表示使用 IndentWidth

ColumnLimit: 0	# 每行最大列宽
BreakAfterAttributes: Leave	# 属性 ([[...]]) 后是否换行
BreakAfterReturnType: None            # 函数返回类型后是否换行
BreakBeforeBinaryOperators: None      # 二元运算符前换行风格：None(运算符后换行), NonAssignment, All
BreakBeforeConceptDeclarations: Always # concept 声明前是否换行：Always, Never, Allowed
BreakBeforeInlineASMColon: OnlyMultiline # 内联汇编的冒号前换行：OnlyMultiline, All
BreakBeforeTernaryOperators: true     # 三元运算符 ? 和 : 前是否换行
BreakConstructorInitializers: BeforeColon # 构造函数初始化列表换行：BeforeColon, BeforeComma, AfterColon
BreakFunctionDefinitionParameters: false	# 函数定义的参数是否在开括号后立即换行
BreakInheritanceList: BeforeColon     # 类继承列表换行风格：BeforeColon, BeforeComma, AfterColon, AfterColonWithComma
BreakStringLiterals: true             # 是否允许在字符串字面量内换行
BreakTemplateDeclarations: Leave      # 模板声明参数列表换行：Leave, No, MultiLine, Yes

BreakBeforeBraces: Custom
BraceWrapping:                 # 自定义大括号换行（仅当 BreakBeforeBraces: Custom 时生效）
    AfterCaseLabel: true
    AfterClass: true
    AfterControlStatement: Always
    AfterEnum: true
    AfterExternBlock: true
    AfterFunction: true
    AfterNamespace: true
    AfterStruct: true
    AfterUnion: true
    BeforeCatch: true
    BeforeElse: true
    BeforeLambdaBody: true
    BeforeWhile: true
    IndentBraces: false
    SplitEmptyFunction: true
    SplitEmptyRecord: true
    SplitEmptyNamespace: true

AlignAfterOpenBracket: BlockIndent	# 开括号后参数对齐方式
AlignArrayOfStructures: Left          # 结构体/类数组对齐：Left, Right, None
AlignConsecutiveAssignments:          # 连续赋值对齐，可设为 {} 或具体配置
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
    AlignCompound: true
    AlignFunctionPointers: false
    PadOperators: true
AlignConsecutiveBitFields:            # 连续位域对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
AlignConsecutiveDeclarations:         # 连续声明对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
    AlignCompound: true
    AlignFunctionPointers: false
    PadOperators: true
AlignConsecutiveMacros:               # 连续宏定义对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
AlignConsecutiveShortCaseStatements:  # 连续短 case 语句对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
    AlignCaseArrows: false
    AlignCaseColons: false
AlignConsecutiveTableGenBreakingDAGArgColons: # 连续 TableGen DAG 参数冒号对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
AlignConsecutiveTableGenCondOperatorColons:   # 连续 TableGen 条件运算符冒号对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
AlignConsecutiveTableGenDefinitionColons:     # 连续 TableGen 定义冒号对齐
    Enabled: false
    AcrossEmptyLines: false
    AcrossComments: false
AlignEscapedNewlines: Left            # 续行符 \ 的对齐风格：DontAlign, Left, Right
AlignOperands: Align                  # 操作数对齐：Align, DontAlign, AlignAfterOperator
AlignTrailingComments:                # 行尾注释对齐
    Kind: Leave                       # Leave, Always, Never
    OverEmptyLines: 0

CommentPragmas: '^ IWYU pragma:'      # 匹配这些正则表达式的注释将不被格式化（视为指令）
ReflowComments: true                  # 是否自动重排注释内容（仅调整行长度，不改变内容）
RemoveSemicolon: false                # 删除冗余的分号（如空语句）

Cpp11BracedListStyle: true            # 使用 C++11 统一初始化列表的大括号风格 { a, b }（前后空格）
DisableFormat: false                  # 完全禁用格式化
ExperimentalAutoDetectBinPacking: false # 是否自动检测参数打包（将所有参数放一行或每行一个）
MaxEmptyLinesToKeep: 1                # 最多保留连续的空行数
QualifierAlignment: Leave             # 限定符对齐：Leave, Left(靠左), Right(靠右), Custom
RequiresClausePosition: OwnLine       # requires 子句位置：OwnLine, WithPreceding, WithFollowing
SeparateDefinitionBlocks: Leave       # 是否将定义块（如函数/类）用空行分隔：Always, Never, Leave
SpaceAfterCStyleCast: false           # C 风格强制转换后是否加空格
SpaceAfterLogicalNot: false           # 逻辑非 ! 后是否加空格
SpaceAfterTemplateKeyword: true       # template 关键字后是否加空格
SpaceAroundPointerQualifiers: Default # 指针限定符 (const/volatile) 空格：Default, Before, After, Both
SpaceBeforeAssignmentOperators: true  # 赋值/复合赋值运算符前是否加空格
SpaceBeforeCaseColon: false           # case 冒号前是否加空格
SpaceBeforeCpp11BracedList: true      # 初始化列表开括号前空格 (vector<int>{...})
SpaceBeforeCtorInitializerColon: true # 构造函数初始化列表冒号前空格
SpaceBeforeInheritanceColon: true     # 继承列表冒号前空格
SpaceBeforeJsonColon: false           # JSON 键值对冒号前空格
SpaceBeforeParens: ControlStatements  # 括号前空格风格：Never, ControlStatements, NonEmptyParentheses, Always, Custom
SpaceBeforeParensOptions:             # 自定义括号前空格（当 SpaceBeforeParens: Custom 时）
    AfterControlStatements: true
    AfterForeachMacros: true
    AfterFunctionDeclarationName: false
    AfterFunctionDefinitionName: false
    AfterIfMacros: true
    AfterOverloadedOperator: false
    AfterPlacementOperator: true
    AfterRequiresInClause: true
    AfterRequiresInExpression: true
    BeforeNonEmptyParentheses: false
SpaceBeforeRangeBasedForLoopColon: true # 基于范围 for 循环冒号前空格
SpaceBeforeSquareBrackets: false      # 方括号 [ 前加空格
SpaceInEmptyBlock: true               # 空大括号内加空格 { }
SpaceInEmptyParentheses: false        # 空圆括号内加空格 ()
SpacesBeforeTrailingComments: 1       # 行尾注释前空格数（需要 AlignTrailingComments 不为 Leave 时使用）
SpacesInAngles: Leave                 # 模板尖括号内空格：Leave(保持原样), Never, Always
SpacesInConditionalStatement: false   # 条件语句关键字后 if( 空格
SpacesInContainerLiterals: true       # 容器字面量内加空格 {1, 2} -> { 1, 2 }
SpacesInCStyleCastParentheses: false  # C 风格转换括号内加空格 (int)x -> ( int )x
SpacesInLineCommentPrefix:            # 行注释 // 后最少与最大空格数
    Minimum: 1
    Maximum: -1                       # -1 表示不限制
SpacesInParentheses: false            # 圆括号内侧是否加空格
SpacesInSquareBrackets: false         # 方括号内侧是否加空格

InsertBraces: false                   # 在 if/for/while 等控制语句中插入大括号（即使只有一条语句）
InsertNewlineAtEOF: false             # 文件末尾是否插入空行
InsertTrailingCommas: None            # 是否插入尾随逗号：None, Wrapped(仅在换行时插入)
KeepEmptyLinesAtTheStartOfBlocks: true # 块起始处的空行是否保留
PenaltyBreakAssignment: 5             # 赋值运算符处换行的惩罚值
PenaltyBreakBeforeFirstCallParameter: 30 # 函数调用第一个参数前换行的惩罚值
PenaltyBreakComment: 10               # 在注释前换行的惩罚值
PenaltyBreakFirstLessLess: 120        # 在 << 前换行的惩罚值（流插入）
PenaltyBreakOpenParenthesis: 0        # 在开括号后换行的惩罚值
PenaltyBreakString: 1000              # 在字符串字面量中换行的惩罚值
PenaltyBreakTemplateDeclaration: 10   # 模板声明换行的惩罚值
PenaltyExcessCharacter: 1000000       # 超出列宽的每个字符惩罚值
PenaltyIndentedWhitespace: 0          # 缩进空格惩罚值（控制缩进多深）
PenaltyReturnTypeOnItsOwnLine: 60     # 返回类型单独占一行的惩罚值

ForEachMacros: ['foreach', 'Q_FOREACH', 'BOOST_FOREACH'] # 被视为 foreach 的宏
IfMacros: ['KJ_IF_SOME']              # 被视为 if 的宏
IncludeBlocks: Preserve               # 包含块分组规则：Preserve, Merge, Regroup

SortIncludes: Never                   # 是否自动排序包含指令：Never, CaseSensitive, CaseInsensitive
SortUsingDeclarations: false          # 是否对 using 声明排序
StatementMacros: ['Q_UNUSED', 'QT_REQUIRE_VERSION'] # 被视为语句的宏

EmptyLineAfterAccessModifier: Leave   # 访问修饰符后空行：Leave, Never, Always
EmptyLineBeforeAccessModifier: Leave  # 访问修饰符前空行：Leave, LogicalBlock, Always

PointerAlignment: Left                # 指针 * 或引用 & 对齐
ReferenceAlignment: Pointer           # 引用 & 对齐：Pointer(跟随 PointerAlignment), Left, Right, Middle

MacroBlockBegin: ''                   # 宏块开始标记，例如 'BEGIN_NAMESPACE'
MacroBlockEnd: ''                     # 宏块结束标记

AllowAllArgumentsOnNextLine: true     # 是否允许将所有参数放到下一行
AllowAllParametersOfDeclarationOnNextLine: true # 是否允许将所有声明参数放到下一行
AllowBreakBeforeNoexceptSpecifier: Never # noexcept 前换行：Never, OnlyThrow, Always
AllowShortBlocksOnASingleLine: Never  # 短块是否允许在单行
AllowShortCaseExpressionOnASingleLine: false	# 短case表达式是否允许单行
AllowShortCompoundRequirementOnASingleLine: true # 复合需求子句是否单行
AllowShortEnumsOnASingleLine: true    # 短枚举是否单行
AllowShortFunctionsOnASingleLine: Inline	# 短函数是否单行
AllowShortIfStatementsOnASingleLine: Never	# 短 if 是否单行
AllowShortLambdasOnASingleLine: All   # 短 lambda 是否单行：None, Empty, Inline, All
AllowShortLoopsOnASingleLine: false   # 短循环是否单行
AlwaysBreakAfterDefinitionReturnType: None # 定义返回类型后强制换行：None, All, TopLevel
AlwaysBreakAfterReturnType: None      # 返回类型后强制换行：None, All, TopLevel
AlwaysBreakBeforeMultilineStrings: false # 多行字符串前是否始终换行
AlwaysBreakTemplateDeclarations: Leave # 模板声明是否换行：Leave, No, MultiLine, Yes
BinPackArguments: false	# 参数打包
BinPackParameters: false	# 声明参数打包
ConstructorInitializerIndentWidth: 4  # 构造函数初始化列表缩进宽度
ContinuationIndentWidth: 4            # 续行缩进宽度
PackConstructorInitializers: BinPack  # 初始化列表打包：BinPack, CurrentLine, NextLine, NextLineOnly

FixNamespaceComments: true            # 自动为长命名空间添加注释 // namespace name
SkipMacroDefinitionBody: false        # 是否跳过宏定义体的格式化